---
/**
 * Form submission confirmation page. Netlify redirects here after a
 * successful contact form submission.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Thanks" description="Thanks for reaching out.">
  <Nav />
  <main class="max-w-5xl mx-auto px-6 py-32 text-center">
    <h1
      class="text-3xl font-semibold tracking-tight mb-4"
      style="letter-spacing: -0.03em;"
    >
      Got it.
    </h1>
    <p class="text-[var(--color-muted)] mb-8">We'll be in touch.</p>
    <a
      href="/"
      class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-dark)] transition-colors"
    >
      ← Back to home
    </a>
  </main>
</BaseLayout>
