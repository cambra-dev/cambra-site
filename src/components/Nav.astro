---
/**
 * Top navigation bar. Logo on the left, blog link on the right.
 */
---

<header
  class="w-full border-b border-gray-100 bg-white/90 backdrop-blur-sm sticky top-0 z-50"
>
  <nav
    class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a href="/" aria-label="Cambra home">
      <img src="/nautilus-cambra.svg" alt="Cambra" class="h-12" />
    </a>

    <div class="flex items-center gap-6 text-sm font-medium">
      <a
        href="/blog"
        class="text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors"
      >
        Blog
      </a>
      <a
        href="/#contact"
        class="text-[var(--color-muted)] hover:text-[var(--color-ink)] transition-colors"
      >
        Contact
      </a>
    </div>
  </nav>
</header>
