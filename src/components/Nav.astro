---
/**
 * Top navigation bar. Brand lockup on the left, blog + contact links on the right.
 */
---

<header
  class="w-full border-b border-[var(--color-san-blas)] bg-[var(--color-bg)]/90 backdrop-blur-sm sticky top-0 z-50"
>
  <nav
    class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a href="/" aria-label="Cambra home" class="flex items-center">
      <img
        src="/brand/logo-horizontal.svg"
        alt="Cambra"
        class="h-9 md:h-10 w-auto"
      />
    </a>

    <div class="flex items-center gap-6 text-sm font-medium">
      <a
        href="/blog"
        class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] transition-colors"
      >
        Blog
      </a>
      <a
        href="/#contact"
        class="text-[var(--color-ink-soft)] hover:text-[var(--color-accent)] transition-colors"
      >
        Contact
      </a>
    </div>
  </nav>
</header>
