---
/**
 * Contact capture section. Netlify Forms processes submissions automatically
 * on deploy — no backend needed. Submissions appear in the Netlify dashboard.
 *
 * Prerequisites:
 *   1. Enable form detection: Netlify dashboard → Site settings → Forms → Enable form detection.
 *   2. The hidden form in public/netlify-forms.html must mirror this form's fields
 *      (Netlify scans it at build time to register the form).
 *
 * To receive email notifications for new submissions:
 *   Netlify dashboard → Forms → contact → Notifications → Add email notification.
 */
import Waves from "./Waves.astro";
---

<section id="contact" class="relative overflow-hidden pt-12 pb-20 md:pt-16 md:pb-28" style="background: var(--color-sand);">
  <div class="max-w-5xl mx-auto px-6">
    <div class="max-w-md">
      <h2
        class="text-2xl md:text-3xl font-semibold tracking-tight mb-3 text-[var(--color-ink)]"
        style="letter-spacing: -0.02em;"
      >
        Stay in the loop.
      </h2>
      <p class="text-[var(--color-ink-soft)] mb-8 leading-relaxed">
        We'll reach out when there's something worth sharing — no spam, no
        marketing, no newsletters.
      </p>

      <!-- Netlify Forms: the hidden input and netlify attribute are required. -->
      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-5"
        action="/thanks"
      >
        <!-- Honeypot for bot filtering -->
        <p class="hidden" aria-hidden="true">
          <label>
            Don't fill this out if you're human: <input name="bot-field" />
          </label>
        </p>
        <input type="hidden" name="form-name" value="contact" />

        <div>
          <label for="email" class="block text-sm font-medium mb-1.5 text-[var(--color-ink)]">
            Email address
          </label>
          <input
            id="email"
            type="email"
            name="email"
            required
            placeholder="you@example.com"
            class="w-full bg-white border border-[var(--color-san-blas)] rounded-md px-3.5 py-2.5 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-muted)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition"
          />
        </div>

        <fieldset>
          <legend class="block text-sm font-medium mb-2 text-[var(--color-ink)]"
            >I'm interested in…</legend
          >
          <div class="space-y-2.5">
            <label class="flex items-center gap-3 cursor-pointer">
              <input
                type="radio"
                name="intent"
                value="following"
                checked
                class="accent-[var(--color-accent)] w-4 h-4"
              />
              <span class="text-sm text-[var(--color-ink)]">Following the project</span>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input
                type="radio"
                name="intent"
                value="joining"
                class="accent-[var(--color-accent)] w-4 h-4"
              />
              <span class="text-sm text-[var(--color-ink)]">Working on this</span>
            </label>
          </div>
        </fieldset>

        <button
          type="submit"
          class="bg-[var(--color-accent)] hover:bg-[var(--color-accent-dark)] text-white text-sm font-medium px-5 py-2.5 rounded-md transition-colors"
        >
          Submit
        </button>
      </form>
    </div>
  </div>

  <!-- Subtle wavy seam into the Team section (San Blas) below -->
  <Waves palette="solid-san-blas" shape="crest" height="clamp(80px, 10vw, 140px)" />
</section>
