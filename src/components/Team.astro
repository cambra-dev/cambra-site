---
/**
 * Team section. Team data lives in src/data/team.ts — update that file,
 * not this component.
 */
import { team } from '../data/team';
---

<section class="relative overflow-hidden pt-12 pb-24 md:pt-16 md:pb-32" style="background: var(--color-san-blas);">
  <div class="max-w-5xl mx-auto px-6">
    <h2
      class="text-2xl md:text-3xl font-semibold tracking-tight mb-12 text-[var(--color-ink)]"
      style="letter-spacing: -0.02em;"
    >
      The team
    </h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-10">
      {team.map((member) => (
        <div class="flex flex-col">
          <img
            src={member.photo}
            alt={member.name}
            width="80"
            height="80"
            class="w-16 h-16 rounded-full object-cover mb-4 bg-[var(--color-bg)]"
            loading="lazy"
          />
          <div>
            <div class="flex items-center gap-2">
              <span class="font-semibold text-[var(--color-ink)]">{member.name}</span>
              {member.link && (
                <a
                  href={member.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${member.name} on LinkedIn`}
                  class="text-[var(--color-ocean)] hover:text-[var(--color-deep-sea)] transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
            </div>
            <p class="text-sm text-[var(--color-accent)] font-medium mt-0.5 mb-2">
              {member.role}
            </p>
            <p class="text-sm text-[var(--color-ink-soft)] leading-relaxed">
              {member.bio}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
